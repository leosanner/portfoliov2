{
  "name": "@portfolio/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply DB --local",
    "db:studio": "drizzle-kit studio",
    "db:seed:admins": "node --experimental-strip-types --env-file=.dev.vars scripts/seed-admin-emails.ts"
  },
  "dependencies": {
    "@portfolio/shared": "workspace:^",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250320.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.6.0"
  }
}
